{
  "name": "@geostrategists/cdk-jwks-rotation",
  "version": "0.0.1",
  "description": "CDK construct for generating and rotating JWT signing keys and JSON Web Key Sets (JWKS)",
  "homepage": "https://github.com/geostrategists/cdk-jwks-rotation#readme",
  "bugs": {
    "url": "https://github.com/geostrategists/cdk-jwks-rotation/issues"
  },
  "author": "Bernhard Frauendienst <bernhard.frauendienst@geostrategists.de>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geostrategists/cdk-jwks-rotation.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "ignore": [
      "!dist/**",
      "src/",
      ".*",
      "tsconfig.json",
      "tsdown.config.ts"
    ],
    "provenance": true
  },
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt . '!**/*.yml' '!**/*.yaml'",
    "format:check": "oxfmt --check . '!**/*.yml' '!**/*.yaml'",
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "prepack": "pnpm build && pnpm npmignore --auto",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1072.0",
    "@aws-sdk/client-secrets-manager": "^3.1072.0",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^24.13.2",
    "@vitest/ui": "^4.1.9",
    "aws-cdk-lib": "^2.260.0",
    "aws-sdk-client-mock": "^4.1.0",
    "constructs": "^10.6.0",
    "jose": "^6.2.3",
    "lefthook": "^2.1.9",
    "nanoid": "^5.1.14",
    "npmignore": "^0.3.5",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.0.0",
    "constructs": "^10.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
